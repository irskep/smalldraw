{
  "name": "@smalldraw/splat",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./documents": "./src/documents/index.ts",
    "./styles.css": "./src/main.css"
  },
  "scripts": {
    "generate:coloring-assets": "bun run ./scripts/generate-coloring-assets.ts",
    "ts:check": "tsc -p tsconfig.json --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "test": "bun test --timeout 4000"
  },
  "dependencies": {
    "@automerge/automerge-repo": "2.5.1",
    "@automerge/automerge-repo-network-broadcastchannel": "2.5.1",
    "@automerge/automerge-repo-network-websocket": "2.5.1",
    "@automerge/automerge-repo-storage-indexeddb": "2.5.1",
    "@smalldraw/core": "workspace:*",
    "@smalldraw/design-system": "workspace:*",
    "@smalldraw/shared": "workspace:*",
    "@smalldraw/geometry": "workspace:*",
    "@smalldraw/renderer-canvas": "workspace:*",
    "@smalldraw/renderer-raster": "workspace:*",
    "@trpc/client": "^11.8.1",
    "lucide": "catalog:ui",
    "nanostores": "^0.11.4",
    "open-props": "catalog:ui",
    "qrcode": "^1.5.4",
    "redom": "catalog:ui"
  },
  "devDependencies": {
    "@automerge/automerge": "^3.2.3",
    "@smalldraw/testing": "workspace:*",
    "@types/qrcode": "^1.5.5",
    "@types/redom": "catalog:ui",
    "canvas": "^3.1.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "catalog:testing"
  }
}
