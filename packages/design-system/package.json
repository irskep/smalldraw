{
  "name": "@smalldraw/design-system",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./dropdown-menu": "./src/view/DropdownMenu.ts",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "dev": "bun ./harness/index.html --watch --host=0.0.0.0:3002",
    "build": "tsup src/index.ts --dts --format esm",
    "ts:check": "tsc -p tsconfig.json --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "test": "bun test ./tests",
    "test:ui": "mise -C ../.. run design-system:test:ui",
    "test:ui:headed": "mise -C ../.. run design-system:test:ui:headed",
    "test:ui:managed": "mise -C ../.. run design-system:test:ui:managed",
    "test:ui:live": "mise -C ../.. run design-system:test:ui",
    "validate": "bun run ts:check && bun run test && bun run test:ui:live",
    "test:ui:install": "bunx playwright install chromium"
  },
  "dependencies": {
    "lucide": "catalog:ui",
    "nanostores": "^0.11.4",
    "open-props": "catalog:ui",
    "redom": "catalog:ui"
  },
  "devDependencies": {
    "@playwright/test": "catalog:testing",
    "@types/redom": "catalog:ui",
    "happy-dom": "catalog:testing",
    "tsup": "catalog:build",
    "typescript": "catalog:build"
  }
}
