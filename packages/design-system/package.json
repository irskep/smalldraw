{
  "name": "@smalldraw/design-system",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "dev": "bun ./harness/index.html --watch --host=0.0.0.0:3002",
    "build": "tsup src/index.ts --dts --format esm",
    "ts:check": "tsc -p tsconfig.json --noEmit",
    "lint": "bunx biome check --write",
    "test": "bun test ./tests",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed"
  },
  "dependencies": {
    "lucide": "catalog:ui",
    "open-props": "catalog:ui",
    "redom": "catalog:ui"
  },
  "devDependencies": {
    "@playwright/test": "catalog:testing",
    "@types/redom": "catalog:ui",
    "happy-dom": "catalog:testing",
    "tsup": "catalog:build",
    "typescript": "catalog:build"
  }
}
