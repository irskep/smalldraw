{
  "name": "automerge-apps-monorepo",
  "private": true,
  "catalogs": {
    "build": {
      "tsup": "^8.5.1",
      "typescript": "^5.9.3"
    },
    "testing": {
      "@playwright/test": "^1.55.1",
      "happy-dom": "^14.10.1"
    },
    "ui": {
      "@types/redom": "^3.2.4",
      "lucide": "^0.563.0",
      "open-props": "^1.7.23",
      "redom": "^3.27.1"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "ts:check": "bun --filter '*' ts:check",
    "test": "bun --filter '*' test",
    "lint": "bun --filter '*' lint",
    "format": "bun run format:check",
    "format:check": "bunx biome format .",
    "format:fix": "bunx biome format --write .",
    "fix:all": "bun run format:fix && bun --filter '*' lint:fix"
  }
}
