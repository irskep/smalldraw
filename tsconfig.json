{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["bun-types"],
    "jsx": "react",
    "paths": {
      "@smalldraw/design-system/styles.css": ["./packages/design-system/src/styles.css"],
      "@smalldraw/splat/styles.css": ["./packages/splat/src/main.css"],
      "@smalldraw/design-system": ["./packages/design-system/src/index.ts"],
      "@smalldraw/core": ["./packages/core/src/index.ts"],
      "@smalldraw/geometry": ["./packages/geometry/src/index.ts"],
      "@smalldraw/*": ["./packages/*/src/index.ts"]
    },
    "noEmit": true
  },
  "exclude": ["node_modules", "dist"]
}
